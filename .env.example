# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# HuggingFace access token (required for pushing models/datasets to Hub)
HF_TOKEN=your_hf_token_here

# Weights & Biases API key (optional — set to enable wandb logging during training)
WANDB_API_KEY=your_wandb_key_here

# HuggingFace Hub repository IDs (update with your actual username)
HF_DATASET_REPO=your-username/cuad-hallucination-labeled
HF_MODEL_REPO=your-username/contractual-hallucination-eliminator
